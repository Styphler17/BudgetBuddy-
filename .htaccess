<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /BudgetBuddy-/

    # Do not rewrite if it's an existing file or directory (allows dist/assets to load)
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d

    # Rewrite all other requests to index.php
    RewriteRule ^(.*)$ index.php [L,QSA]
</IfModule>

# Security: Deny access to app, config, and backend folders
<FilesMatch "^(app|config|backend|node_modules)">
    Order allow,deny
    Deny from all
</FilesMatch>
