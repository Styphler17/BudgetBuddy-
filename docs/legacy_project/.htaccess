<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /BudgetBuddy-/
  
  # Redirect root of subdirectory to dist/index.html
  RewriteRule ^$ dist/index.html [L]
  
  # Check if the request is for a file inside the dist folder
  # We use the relative path since RewriteBase is set
  RewriteCond %{REQUEST_URI} !^/BudgetBuddy-/dist/
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^(.*)$ dist/$1 [L]
  
  # Route all other requests to dist/index.html (Single Page App)
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule . dist/index.html [L]
</IfModule>
